APP_ENV=staging
PUREHUB_PHASE=phase-1
NEXT_PUBLIC_APP_VERSION=0.1.0

HTTP_PORT=80
PUREHUB_IMAGE=purehub-web:local
NPM_REGISTRY=https://registry.npmjs.org/
# If npmjs.org is slow from your server region, set:
# NPM_REGISTRY=https://registry.npmmirror.com/

POSTGRES_DB=purehub
POSTGRES_USER=purehub
POSTGRES_PASSWORD=change-this-password
DATABASE_URL=postgresql://purehub:change-this-password@postgres:5432/purehub?schema=public

# Health checks inside docker-compose use service names.
DB_HOST=postgres
DB_PORT=5432
REDIS_HOST=redis
REDIS_PORT=6379

# Payment providers are configured in the admin UI in later phases.
STRIPE_WEBHOOK_SECRET=
PAYPAL_WEBHOOK_ID=
USDT_TRC20_RECEIVE_ADDRESS=
USDT_ERC20_RECEIVE_ADDRESS=
