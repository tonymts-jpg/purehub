APP_ENV=staging
PUREHUB_PHASE=phase-6
NEXT_PUBLIC_APP_VERSION=0.1.0
NEXT_PUBLIC_DEMO_MODE=false
NEXT_PUBLIC_APP_URL=http://127.0.0.1
BETTER_AUTH_URL=http://127.0.0.1
BETTER_AUTH_SECRET=change-this-to-at-least-32-random-characters
BETTER_AUTH_SECURE_COOKIES=false
DEMO_ACCOUNT_PASSWORD=change-this-demo-account-password
SERVICE_ADMIN_USER_ID=admin-demo

HTTP_PORT=80

# Phase 3 staging/admin guard. Change this on every server and never commit real secrets.
ADMIN_ACCESS_TOKEN=purehub-admin-demo-token
WORKER_ACCESS_TOKEN=change-this-worker-token

PUREHUB_IMAGE=purehub-web:local
NPM_REGISTRY=https://registry.npmjs.org/
# If npmjs.org is slow from your server region, set:
# NPM_REGISTRY=https://registry.npmmirror.com/

POSTGRES_DB=purehub
POSTGRES_USER=purehub
POSTGRES_PASSWORD=change-this-password
DATABASE_URL=postgresql://purehub:change-this-password@postgres:5432/purehub?schema=public

# Health checks inside docker-compose use service names.
DB_HOST=postgres
DB_PORT=5432
REDIS_HOST=redis
REDIS_PORT=6379

# Phase 4 payment providers are configured in the admin UI.
# Keep real provider secrets out of git. The seeded card channel uses manual confirmation for sandbox tests.
STRIPE_WEBHOOK_SECRET=
PAYPAL_WEBHOOK_ID=
USDT_TRC20_RECEIVE_ADDRESS=
USDT_ERC20_RECEIVE_ADDRESS=

# Phase 5 private media storage. Staging uses the bundled MinIO service.
MINIO_ROOT_USER=purehub-minio
MINIO_ROOT_PASSWORD=change-this-minio-password
OBJECT_STORAGE_BUCKET=purehub-media
OBJECT_STORAGE_REGION=us-east-1
