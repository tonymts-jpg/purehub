generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id
  name                String
  handle              String               @unique
  avatar              String
  email               String               @unique
  emailVerified       Boolean              @default(false)
  image               String?
  status              String               @default("active")
  role                String               @default("fan")
  creatorStatus       String               @default("none")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  creatorProfile      CreatorProfile?
  creatorApplications CreatorApplication[]
  posts               Post[]
  follows             Follow[]
  followers           Follow[]             @relation("FollowedCreator")
  bookmarks           Bookmark[]
  postLikes           PostLike[]
  postComments        PostComment[]
  notifications       Notification[]       @relation("NotificationRecipient")
  notificationActions Notification[]       @relation("NotificationActor")
  sessions            Session[]
  accounts            Account[]
  subscriptions       Subscription[]
  entitlements        Entitlement[]
  transactions        Transaction[]
  buyerOrders         Order[]              @relation("BuyerOrders")
  creatorOrders       Order[]              @relation("CreatorOrders")
  walletBalance       WalletBalance?
  payoutRequests      PayoutRequest[]
  kycCase             KycCase?
  adminAccounts       AdminAccount[]
  auditLogs           AuditLog[]
}

model CreatorProfile {
  id        String           @id
  userId    String           @unique
  bio       String
  category  String
  followers Int              @default(0)
  members   Int              @default(0)
  cover     String
  verified  Boolean          @default(false)
  levelId   String?
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  level     CreatorLevel?    @relation(fields: [levelId], references: [id])
  plans     MembershipPlan[]
}

model CreatorApplication {
  id          String    @id
  userId      String
  status      String    @default("pending")
  displayName String
  category    String
  portfolio   String
  contact     String
  note        String?
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MembershipPlan {
  id        String         @id
  creatorId String
  name      String
  price     Int
  color     String
  benefits  Json
  creator   CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
}

model Post {
  id           String        @id
  creatorId    String
  title        String
  excerpt      String
  content      String
  cover        String
  category     String
  tags         Json
  visibility   String
  contentType  String        @default("photo_short")
  saleMode     String        @default("subscription_only")
  price        Int?
  likes        Int           @default(0)
  comments     Json
  createdLabel String        @default("刚刚")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  creator      User          @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  media        MediaAsset[]
  bookmarks    Bookmark[]
  postLikes    PostLike[]
  commentItems PostComment[]
  notifications Notification[]
  entitlements Entitlement[]
}

model MediaAsset {
  id              String   @id @default(cuid())
  postId          String?
  uploaderUserId  String?
  src             String   @default("")
  alt             String
  width           Int
  height          Int
  order           Int
  kind            String   @default("image")
  durationSeconds Int?
  mimeType        String   @default("image/jpeg")
  sizeBytes       Int      @default(0)
  checksum        String?
  storageKey      String?  @unique
  derivativeKey   String?
  status          String   @default("ready")
  visibility      String   @default("public")
  processingError String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  post            Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Follow {
  id        String   @id @default(cuid())
  userId    String
  creatorId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  creator   User     @relation("FollowedCreator", fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([userId, creatorId])
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model PostLike {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId, createdAt])
}

model PostComment {
  id            String         @id @default(cuid())
  postId        String
  authorId      String
  content       String
  status        String         @default("visible")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  post          Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  author        User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  notifications Notification[]

  @@index([postId, createdAt])
}

model Notification {
  id              String       @id @default(cuid())
  recipientUserId String
  actorUserId     String?
  type            String
  eventKey        String       @unique
  postId          String?
  commentId       String?
  orderId         String?
  readAt          DateTime?
  createdAt       DateTime     @default(now())
  recipient       User         @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)
  actor           User?        @relation("NotificationActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  post            Post?        @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment         PostComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  order           Order?       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([recipientUserId, createdAt])
  @@index([recipientUserId, readAt])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model Subscription {
  id        String   @id
  userId    String
  creatorId String
  planId    String
  orderId   String?
  status    String   @default("active")
  startedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
}

model Entitlement {
  id        String   @id
  userId    String
  postId    String
  orderId   String?
  source    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@unique([userId, postId, source])
}

model Transaction {
  id        String   @id
  userId    String
  orderId   String?
  title     String
  amount    Int
  type      String
  dateLabel String
  status    String
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
}

model WalletBalance {
  id        String   @id @default(cuid())
  userId    String   @unique
  available Int      @default(0)
  pending   Int      @default(0)
  reserved  Int      @default(0)
  debt      Int      @default(0)
  currency  String   @default("CNY")
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PayoutRequest {
  id                  String    @id @default(cuid())
  userId              String
  amount              Int
  status              String    @default("pending")
  channel             String
  reviewNote          String    @default("")
  reviewedAt          DateTime?
  reviewedBy          String?
  ledgerTransactionId String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PlatformFeeConfig {
  id          String    @id @default(cuid())
  name        String
  feeBps      Int
  status      String    @default("draft")
  activatedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Order {
  id                  String               @id @default(cuid())
  buyerUserId         String
  creatorUserId       String
  kind                String
  itemId              String
  amount              Int
  currency            String               @default("CNY")
  status              String               @default("pending")
  provider            String?
  platformFeeBps      Int                  @default(0)
  platformFeeAmount   Int                  @default(0)
  creatorNetAmount    Int                  @default(0)
  metadata            Json                 @default("{}")
  paidAt              DateTime?
  fulfilledAt         DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  buyer               User                 @relation("BuyerOrders", fields: [buyerUserId], references: [id], onDelete: Cascade)
  creator             User                 @relation("CreatorOrders", fields: [creatorUserId], references: [id], onDelete: Cascade)
  paymentIntents      PaymentIntent[]
  paymentTransactions PaymentTransaction[]
  subscriptions       Subscription[]
  entitlements        Entitlement[]
  transactions        Transaction[]
  notifications       Notification[]
}

model PaymentIntent {
  id                  String               @id @default(cuid())
  orderId             String
  provider            String
  status              String               @default("requires_confirmation")
  amount              Int
  currency            String               @default("CNY")
  providerIntentId    String?
  clientSecret        String?
  manualInstructions  Json                 @default("{}")
  metadata            Json                 @default("{}")
  confirmedAt         DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  order               Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  paymentTransactions PaymentTransaction[]
}

model WebhookEvent {
  id              String    @id @default(cuid())
  provider        String
  providerEventId String
  eventType       String
  status          String    @default("received")
  payload         Json
  processedAt     DateTime?
  createdAt       DateTime  @default(now())

  @@unique([provider, providerEventId])
}

model PaymentTransaction {
  id                String         @id @default(cuid())
  orderId           String
  paymentIntentId   String?
  provider          String
  amount            Int
  currency          String         @default("CNY")
  status            String
  platformFeeBps    Int
  platformFeeAmount Int
  creatorNetAmount  Int
  availableAt       DateTime?
  settledAt         DateTime?
  metadata          Json           @default("{}")
  createdAt         DateTime       @default(now())
  order             Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  paymentIntent     PaymentIntent? @relation(fields: [paymentIntentId], references: [id], onDelete: SetNull)
}

model LedgerAccount {
  id          String        @id @default(cuid())
  key         String        @unique
  ownerUserId String?
  type        String
  currency    String        @default("CNY")
  balance     Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  entries     LedgerEntry[]
}

model LedgerTransaction {
  id             String        @id @default(cuid())
  idempotencyKey String        @unique
  type           String
  referenceType  String
  referenceId    String
  currency       String        @default("CNY")
  status         String        @default("posted")
  metadata       Json          @default("{}")
  createdAt      DateTime      @default(now())
  entries        LedgerEntry[]
}

model LedgerEntry {
  id            String            @id @default(cuid())
  transactionId String
  accountId     String
  amount        Int
  createdAt     DateTime          @default(now())
  transaction   LedgerTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  account       LedgerAccount     @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([transactionId])
  @@index([accountId])
}

model SettlementConfig {
  id          String    @id @default(cuid())
  name        String
  holdDays    Int       @default(7)
  status      String    @default("draft")
  activatedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Refund {
  id                  String   @id @default(cuid())
  orderId             String   @unique
  reason              String
  status              String   @default("succeeded")
  source              String   @default("admin")
  ledgerTransactionId String?
  createdBy           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model KycCase {
  id           String    @id @default(cuid())
  userId       String    @unique
  status       String    @default("pending")
  legalName    String
  countryCode  String
  documentKeys Json
  reviewNote   String    @default("")
  reviewedAt   DateTime?
  reviewedBy   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ReconciliationRun {
  id               String    @id @default(cuid())
  status           String    @default("completed")
  paymentCount     Int       @default(0)
  ledgerCount      Int       @default(0)
  walletCount      Int       @default(0)
  discrepancyCount Int       @default(0)
  discrepancies    Json      @default("[]")
  startedAt        DateTime  @default(now())
  completedAt      DateTime?
}

model CreatorLevel {
  id           String           @id
  name         String
  minFollowers Int
  maxFollowers Int?
  updatedAt    DateTime         @updatedAt
  creators     CreatorProfile[]
  priceTiers   PriceTier[]
}

model PricingVersion {
  id          String      @id @default(cuid())
  name        String
  status      String      @default("draft")
  publishedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  tiers       PriceTier[]
}

model PriceTier {
  id               String         @id
  levelId          String
  pricingVersionId String         @default("pricing-v1")
  contentType      String
  saleMode         String
  price            Int
  currency         String         @default("CNY")
  active           Boolean        @default(true)
  level            CreatorLevel   @relation(fields: [levelId], references: [id], onDelete: Cascade)
  pricingVersion   PricingVersion @relation(fields: [pricingVersionId], references: [id], onDelete: Cascade)
}

model AdminAccount {
  id        String   @id @default(cuid())
  userId    String
  role      String
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actorRole   String
  action      String
  targetType  String
  targetId    String
  metadata    Json
  createdAt   DateTime @default(now())
  actor       User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
}

model PaymentChannelConfig {
  id         String   @id @default(cuid())
  provider   String   @unique
  enabled    Boolean  @default(false)
  mode       String   @default("test")
  currencies Json
  regions    Json
  feeNote    String   @default("")
  config     Json
  statusNote String   @default("not_configured")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
